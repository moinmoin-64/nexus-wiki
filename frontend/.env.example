# Nexus Frontend Environment Configuration

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# WebSocket Configuration
VITE_WS_PROTO=ws
VITE_WS_HOST=localhost:3001

# Editor Configuration
VITE_EDITOR_AUTOSAVE_INTERVAL=5000
VITE_EDITOR_MAX_HISTORY=100

# Feature Flags
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_GRAPH_VIEW=true
VITE_ENABLE_AI_SUGGESTIONS=false
