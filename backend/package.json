{
  "name": "nexus-backend",
  "version": "1.0.0",
  "description": "Project Nexus Backend - API Bridge & Services",
  "main": "api/server.js",
  "scripts": {
    "start": "node dist/api/server.js",
    "dev": "ts-node api/server.ts",
    "build": "tsc",
    "migrate": "ts-node scripts/migrate.ts",
    "migrate:rollback": "ts-node scripts/rollback.ts",
    "seed": "ts-node scripts/seed.ts",
    "graph-mirror": "python3 services/graph-mirror.py",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"api/**/*.ts\" \"services/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "redis": "^4.6.11",
    "pg": "^8.11.0",
    "neo4j-driver": "^5.14.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.0",
    "joi": "^17.11.0",
    "winston": "^3.10.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-ws": "^3.0.4",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.1.1",
    "prettier": "^3.1.1",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
