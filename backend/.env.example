# Project Nexus Backend Environment Configuration

# Server
PORT=3001
NODE_ENV=production

# PostgreSQL Database
POSTGRES_URL=postgresql://nexus_user:password@localhost:5432/nexus_db

# Neo4j Graph Database
NEO4J_BOLT_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# Graph Mirror Service
GRAPH_SYNC_INTERVAL=300

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=https://wiki-oliver.duckdns.org

# JWT (future)
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=7d
